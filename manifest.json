{
  "manifest_version": 3,
  "name": "HeartShield",
  "version": "1.0",
  "description": "Protection contre le harcèlement et les contenus toxiques.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://discord.com/*",
    "https://www.instagram.com/*",
    "https://www.reddit.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/iconheartshield.png"
    }
  },
  "icons": {
    "16": "icons/iconheartshield.png",
    "48": "icons/iconheartshield.png",
    "128": "icons/iconheartshield.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*",
        "https://discord.com/*",
        "https://www.instagram.com/*",
        "https://www.reddit.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}